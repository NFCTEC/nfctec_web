# Database
DATABASE_URL=postgresql://nfctec:nfctec_dev@localhost:5432/nfctec_web

# API
PORT=3000
NODE_ENV=development
PUBLIC_API_URL=http://localhost:3000
PUBLIC_SITE_URL=https://www.nfctec.com
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# JWT — change in production
JWT_SECRET=dev-jwt-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Uploads
UPLOAD_DIR=./uploads

# Seed (first run only)
SEED_ADMIN_EMAIL=admin@nfctec.com
SEED_ADMIN_PASSWORD=changeme123

# SMTP (GoDaddy / secureserver.net)
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_USER=support@nfctec.com
SMTP_PASS=your-mailbox-password
INQUIRY_NOTIFY_TO=support@nfctec.com
